        {
            "name": "debug",
            "hpcQueueName": "debug",
            "description": "Priority access to shared nodes set aside for testing of jobs with short walltime and limited resources",
            "maxJobs": -1,
            "maxJobsPerUser": 2,
            "minNodeCount": 1,
            "maxNodeCount": 2,
            "minCoresPerNode": 1,
            "maxCoresPerNode": 128,
            "minMemoryMB": 1,
            "maxMemoryMB": 256000,
            "minMinutes": 1,
            "maxMinutes": 30
        },
        {
            "name": "gpu-debug",
            "hpcQueueName": "gpu-debug",
            "description": "Priority access to gpu-shared nodes set aside for testing of jobs with short walltime and limited resources; max two gpus per job",
            "schedulerOptions": [
                {
                    "name": "gpus",
                    "description": "Select the amount of GPUs for this job",
                    "inputMode": "INCLUDE_BY_DEFAULT",
                    "arg": "1",
                    "notes": {
                        "type": "number",
                        "min": "1",
                        "max": "2"
                    }
                }
            ],
            "maxJobs": -1,
            "maxJobsPerUser": 2,
            "minNodeCount": 1,
