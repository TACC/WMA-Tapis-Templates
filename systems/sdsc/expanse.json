            "maxJobs": -1,
            "maxJobsPerUser": 4,
            "minNodeCount": 1,
            "maxNodeCount": 1,
            "minCoresPerNode": 1,
            "maxCoresPerNode": 128,
            "minMemoryMB": 1,
            "maxMemoryMB": 2000000,
            "minMinutes": 1,
            "maxMinutes": 1440
