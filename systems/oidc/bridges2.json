        {
            "name": "GPU-shared",
            "hpcQueueName": "GPU-shared",
            "description": "GPU-shared (CPU, standard compute)",
            "maxJobs": -1,
            "maxJobsPerUser": 20,
            "minNodeCount": 1,
            "maxNodeCount": 32,
            "minCoresPerNode": 1,
            "maxCoresPerNode": 80,
            "minMemoryMB": 1,
            "maxMemoryMB": 256000,
            "minMinutes": 1,
            "maxMinutes": 2880
        }
    ],
    "batchDefaultLogicalQueue": "skx",
    "batchSchedulerProfile": "tacc-apptainer",
    "jobCapabilities": [],
    "tags": [],
    "notes": {
        "label": "Bridges2"
    }
}
