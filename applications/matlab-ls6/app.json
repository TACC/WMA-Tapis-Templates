{
    "id": "matlab_ls6",
    "version": "9.13.1",
    "description": "Run an interactive MATLAB 2022b session on LoneStar6. Submit a help ticket to get your license configured or approved.",
    "owner": "${apiUserId}",
    "enabled": true,
    "runtime": "ZIP",
    "runtimeVersion": null,
    "runtimeOptions": null,
    "containerImage": "tapis://cloud.data/corral/tacc/aci/CEP/applications/v3/matlab-ls6/9.13.1/matlab-ls6.zip",
    "jobType": "BATCH",
    "maxJobs": -1,
    "maxJobsPerUser": -1,
    "strictFileInputs": true,
    "jobAttributes": {
        "description": "Run an interactive MATLAB 2022b session on LoneStar6. Submit a help ticket to get your license configured or approved.",
        "dynamicExecSystem": false,
        "execSystemConstraints": null,
        "execSystemId": "ls6",
        "execSystemExecDir": "${JobWorkingDir}",
        "execSystemInputDir": "${JobWorkingDir}",
        "execSystemOutputDir": "${JobWorkingDir}/output",
        "execSystemLogicalQueue": "development",
        "archiveSystemId": "ls6",
        "archiveSystemDir": "HOST_EVAL($WORK)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
        "archiveOnAppError": true,
        "isMpi": false,
        "mpiCmd": null,
        "cmdPrefix": null,
        "parameterSet": {
            "appArgs": [],
            "containerArgs": [],
            "schedulerOptions": [
                {
                    "name": "MATLAB TACC Scheduler Profile",
                    "description": "Scheduler profile for TACC MATLAB R2022b.",
                    "inputMode": "FIXED",
                    "arg": "--tapis-profile matlab_2022b_ls6",
                    "notes": {
                        "isHidden": true
                    }
                },
                {
                    "name": "TACC Interactive Session Substrings",
                    "description": "VNC and DCV sessions require the substrings 'tap_' and '-dcvserver' in the slurm job name in order to function.",
                    "inputMode": "FIXED",
                    "arg": "--job-name ${JobName}-dcvserver-tap_",
                    "notes": {
                        "isHidden": true
                    }
                }
            ],
            "envVariables": [
                {
                    "key": "_XTERM_CMD",
                    "value": "swr -t 8 matlab",
                    "description": "Command launched within the interactive session.",
                    "inputMode": "FIXED",
                    "notes": {
                        "isHidden": true
                    }
                },
                {
                    "key": "APPEND_PATH",
                    "value": "$PATH",
                    "description": "Append host $PATH to runtime default $PATH.",
                    "inputMode": "FIXED",
                    "notes": {
                        "isHidden": true
                    }
                }
            ],
            "archiveFilter": {
                "includes": [],
                "excludes": [],
                "includeLaunchFiles": true
            }
        },
        "fileInputs": [],
        "fileInputArrays": [],
        "nodeCount": 1,
        "coresPerNode": 128,
        "memoryMB": 256000,
        "maxMinutes": 120,
        "subscriptions": [],
        "tags": []
    },
    "tags": [
        "portalName: UTRC",
        "portalName: 3DEM",
        "portalName: CEP",
        "portalName: PTDATAX"
    ],
    "notes": {
        "licenseType": "MATLAB",
        "label": "MATLAB R2022b Interactive (LoneStar6)",
        "helpUrl": "https://docs.tacc.utexas.edu/software/matlab/",
        "hideNodeCountAndCoresPerNode": false,
        "isInteractive": true,
        "icon": "matlab",
        "category": "Data Processing"
    }
}
