{
    "id": "paraview-ls6",
    "version": "5.13.4",
    "description": "Run an interactive Paraview session on Lonestar 6.",
    "owner": "${apiUserId}",
    "enabled": true,
    "runtime": "ZIP",
    "runtimeVersion": null,
    "runtimeOptions": null,
    "containerImage": "tapis://cloud.data/corral/tacc/aci/CEP/applications/v3/paraview-ls6/paraview-ls6_app.zip",
    "jobType": "BATCH",
    "maxJobs": -1,
    "maxJobsPerUser": -1,
    "strictFileInputs": true,
    "jobAttributes": {
        "description": "Run an interactive Paraview session on Lonestar 6.",
        "dynamicExecSystem": false,
        "execSystemConstraints": null,
        "execSystemId": "ls6",
        "execSystemExecDir": "${JobWorkingDir}",
        "execSystemInputDir": "${JobWorkingDir}",
        "execSystemOutputDir": "${JobWorkingDir}/output",
        "execSystemLogicalQueue": "development",
        "archiveSystemId": "ls6",
        "archiveSystemDir": "HOST_EVAL($WORK)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
        "archiveOnAppError": true,
        "isMpi": false,
        "mpiCmd": null,
        "cmdPrefix": null,
        "parameterSet": {
            "appArgs": [],
            "containerArgs": [],
            "schedulerOptions": [
                {
                    "name": "Paraview TACC Scheduler Profile",
                    "description": "Scheduler profile for TACC Paraview 5.13.3.",
                    "inputMode": "FIXED",
                    "arg": "--tapis-profile Paraview_5.13.3_ls6",
                    "notes": {
                        "isHidden": true
                    }
                },
                {
                    "name": "TACC Interactive Session Substrings",
                    "description": "VNC and DCV sessions require the substrings 'tap_' and '-dcvserver' in the slurm job name in order to function.",
                    "inputMode": "FIXED",
                    "arg": "--job-name ${JobName}-dcvserver-tap_",
                    "notes": {
                        "isHidden": true
                    }
                }
            ],
            "envVariables": [
                {
                    "key": "_XTERM_CMD",
                    "value": "paraview",
                    "description": "Command launched within the interactive session.",
                    "inputMode": "FIXED",
                    "notes": {
                        "isHidden": true
                    }
                },
                {
                    "key": "APPEND_PATH",
                    "value": "$PATH",
                    "description": "Append host $PATH to runtime default $PATH.",
                    "inputMode": "FIXED",
                    "notes": {
                        "isHidden": true
                    }
                },
                {
                    "key": "LD_LIBRARY_PATH",
                    "value": "$LD_LIBRARY_PATH",
                    "description": "LD_LIBRARY_PATH to bring in path for loaded modules",
                    "inputMode": "FIXED",
                    "notes": {
                        "isHidden": true
                    }
                }
            ],
            "archiveFilter": {
                "includes": [],
                "excludes": [],
                "includeLaunchFiles": true
            }
        },
        "fileInputs": [
            {
                "name": "Working Directory",
                "description": "The directory containing the files that you want to work on. This directory and its files will be copied to where your Paraview session runs.",
                "inputMode": "OPTIONAL",
                "autoMountLocal": true,
                "sourceUrl": null,
                "targetPath": "*",
                "notes": {
                    "selectionMode": "directory"
                }
            }
        ],
        "fileInputArrays": [],
        "nodeCount": 1,
        "coresPerNode": 128,
        "memoryMB": 256000,
        "maxMinutes": 120,
        "subscriptions": [],
        "tags": []
    },
    "tags": [
        "portalName: UTRC",
        "portalName: CEP",
        "portalName: PTDATAX",
        "portalName: DesignSafe"
    ],
    "notes": {
        "label": "Paraview (LoneStar6)",
        "helpUrl": "https://www.designsafe-ci.org/user-guide/tools/visualization/#paraview-user-guide",
        "hideNodeCountAndCoresPerNode": true,
        "isInteractive": true,
        "icon": "Paraview",
        "category": "Visualization"
    }
}
